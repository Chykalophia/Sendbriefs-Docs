# SendBriefs Docs — environment variables.
# Copy this to `.env` (gitignored) and fill in real values.

# Canonical site URL. Used for:
#   - sitemap.xml + sitemap-index.xml
#   - Open Graph absolute URLs
#   - Canonical link tags
#
# Default if unset: https://docs.sendbriefs.com
SITE_URL=https://docs.sendbriefs.com
