---
/**
 * SendBriefsMark — the stacked-papers brand mark.
 * Matches the marketing logo at public/logo.svg, but inline so it can
 * inherit color / be sized without an HTTP request.
 *
 * Props:
 *   size      — pixel size (square); default 32
 *   decorative — if true, hides from a11y tree (use when accompanying text says "SendBriefs")
 */

interface Props {
  size?: number;
  decorative?: boolean;
}

const { size = 32, decorative = false } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 64 64"
  xmlns="http://www.w3.org/2000/svg"
  role={decorative ? 'presentation' : 'img'}
  aria-label={decorative ? undefined : 'SendBriefs'}
  aria-hidden={decorative ? 'true' : undefined}
  focusable="false"
>
  <defs>
    <linearGradient id="sb-mark-g" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#4F46E5"></stop>
      <stop offset="100%" stop-color="#7C3AED"></stop>
    </linearGradient>
  </defs>
  <rect x="14" y="24" width="36" height="34" rx="6" fill="#E0E7FF"></rect>
  <rect x="10" y="16" width="36" height="34" rx="6" fill="#C7D2FE"></rect>
  <rect x="6" y="8" width="36" height="34" rx="6" fill="url(#sb-mark-g)"></rect>
  <line x1="12" y1="18" x2="32" y2="18" stroke="#FFFFFF" stroke-width="2.5" stroke-linecap="round"
  ></line>
  <line
    x1="12"
    y1="25"
    x2="28"
    y2="25"
    stroke="#FFFFFF"
    stroke-width="2.5"
    stroke-linecap="round"
    opacity="0.75"></line>
  <line
    x1="12"
    y1="32"
    x2="30"
    y2="32"
    stroke="#FFFFFF"
    stroke-width="2.5"
    stroke-linecap="round"
    opacity="0.55"></line>
</svg>
