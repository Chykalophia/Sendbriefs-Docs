---
/**
 * StartCardGrid — homepage "pick your starting point" cards.
 *
 * A four-up responsive grid (2x2 desktop, 1-col mobile) with a colored
 * icon chip, a heading, a one-line description, and a CTA link. Hovers
 * lift the card and reveal a gradient outline. Each card is itself a
 * full-bleed link target so the entire surface is clickable.
 *
 * Replaces Starlight's <CardGrid stagger> which produces a misaligned
 * two-column layout that breaks at most viewport widths.
 */

interface Item {
  title: string;
  body: string;
  href: string;
  cta: string;
  hue: 'gold' | 'blue' | 'sage' | 'coral';
  icon: 'rocket' | 'cog' | 'book' | 'doc';
}

const items: Item[] = [
  {
    title: 'New here?',
    body: 'Get from signup to your first sent brief in about 35 minutes.',
    cta: 'Start the Getting Started track',
    href: '/getting-started/welcome/',
    hue: 'gold',
    icon: 'rocket',
  },
  {
    title: 'Building a workflow?',
    body: 'Recipes for the standard cycles: monthly reporting, client onboarding, recurring templates, approvals, year-end reviews.',
    cta: 'Browse workflows',
    href: '/flows/monthly-reporting/',
    hue: 'blue',
    icon: 'cog',
  },
  {
    title: 'Looking for a feature?',
    body: 'Reference for briefs, clients, reports, workspaces, integrations, and notifications.',
    cta: 'Browse features',
    href: '/features/briefs/',
    hue: 'sage',
    icon: 'book',
  },
  {
    title: 'Billing question?',
    body: 'Plans, invoices, payment methods, plan changes, cancellation.',
    cta: 'See billing docs',
    href: '/billing/plans/',
    hue: 'coral',
    icon: 'doc',
  },
];
---

<ul class="sb-start-grid" role="list">
  {items.map((item, i) => (
    <li class="sb-start-card-wrap" style={`--sb-card-delay:${i * 60}ms`}>
      <a class={`sb-start-card sb-start-card--${item.hue}`} href={item.href}>
        <span class="sb-start-card-glow" aria-hidden="true"></span>

        <span class={`sb-start-card-icon sb-start-card-icon--${item.hue}`} aria-hidden="true">
          {item.icon === 'rocket' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09zM12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" />
              <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5" />
            </svg>
          )}
          {item.icon === 'cog' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3" />
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
            </svg>
          )}
          {item.icon === 'book' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
            </svg>
          )}
          {item.icon === 'doc' && (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <polyline points="14 2 14 8 20 8" />
              <line x1="8" y1="13" x2="16" y2="13" />
              <line x1="8" y1="17" x2="13" y2="17" />
            </svg>
          )}
        </span>

        <h3 class="sb-start-card-title">{item.title}</h3>
        <p class="sb-start-card-body">{item.body}</p>

        <span class="sb-start-card-cta">
          {item.cta}
          <svg class="sb-start-card-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </span>
      </a>
    </li>
  ))}
</ul>

<style>
  .sb-start-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    list-style: none;
    margin: 1.5rem 0 0;
    padding: 0;
  }

  @media (min-width: 48rem) {
    .sb-start-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.25rem;
    }
  }

  .sb-start-card-wrap {
    margin: 0;
    padding: 0;
    opacity: 0;
    transform: translateY(8px);
    animation: sb-card-in 600ms var(--sb-ease-out-expo) forwards;
    animation-delay: var(--sb-card-delay, 0ms);
  }

  @keyframes sb-card-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .reduce-motion .sb-start-card-wrap,
  :global(.reduce-motion) .sb-start-card-wrap {
    animation: none;
    opacity: 1;
    transform: none;
  }

  .sb-start-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    height: 100%;
    padding: 1.5rem 1.5rem 1.375rem;
    border-radius: var(--sb-radius-xl);
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline);
    color: var(--sl-color-text);
    text-decoration: none;
    box-shadow: var(--sb-shadow-card);
    transition:
      transform var(--sb-duration-base) var(--sb-ease-out-quart),
      box-shadow var(--sb-duration-base) var(--sb-ease-out-quart),
      border-color var(--sb-duration-base) var(--sb-ease-out-quart);
    overflow: hidden;
    isolation: isolate;
  }

  .sb-start-card:hover,
  .sb-start-card:focus-visible {
    transform: translateY(-3px);
    border-color: transparent;
    box-shadow: var(--sb-shadow-card-hover);
    text-decoration: none;
  }

  /* Gradient hairline that reveals on hover */
  .sb-start-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: var(--sb-gradient-featured);
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask-composite: exclude;
    opacity: 0;
    transition: opacity var(--sb-duration-base) var(--sb-ease-out-quart);
    pointer-events: none;
  }
  .sb-start-card:hover::before,
  .sb-start-card:focus-visible::before {
    opacity: 1;
  }

  /* Soft radial glow that follows the card on hover */
  .sb-start-card-glow {
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: inherit;
    background:
      radial-gradient(
        60% 80% at 0% 0%,
        var(--sb-card-glow, rgba(79, 70, 229, 0.18)) 0%,
        transparent 60%
      );
    opacity: 0;
    transition: opacity var(--sb-duration-slow) var(--sb-ease-out-quart);
  }
  .sb-start-card:hover .sb-start-card-glow,
  .sb-start-card:focus-visible .sb-start-card-glow {
    opacity: 1;
  }

  .sb-start-card--gold {
    --sb-card-glow: rgba(245, 158, 11, 0.18);
  }
  .sb-start-card--blue {
    --sb-card-glow: rgba(79, 70, 229, 0.22);
  }
  .sb-start-card--sage {
    --sb-card-glow: rgba(16, 185, 129, 0.18);
  }
  .sb-start-card--coral {
    --sb-card-glow: rgba(236, 72, 153, 0.18);
  }

  /* Icon chip */
  .sb-start-card-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--sb-radius-md);
    transition: transform var(--sb-duration-base) var(--sb-ease-out-quart);
  }

  .sb-start-card:hover .sb-start-card-icon,
  .sb-start-card:focus-visible .sb-start-card-icon {
    transform: scale(1.06) rotate(-2deg);
  }

  .sb-start-card-icon--gold {
    background: var(--sb-hue-gold-bg);
    color: var(--sb-hue-gold);
  }
  .sb-start-card-icon--blue {
    background: var(--sb-hue-blue-bg);
    color: var(--sb-hue-blue);
  }
  .sb-start-card-icon--sage {
    background: var(--sb-hue-sage-bg);
    color: var(--sb-hue-sage);
  }
  .sb-start-card-icon--coral {
    background: var(--sb-hue-coral-bg);
    color: var(--sb-hue-coral);
  }

  :root[data-theme='dark'] .sb-start-card-icon--gold {
    background: rgba(245, 158, 11, 0.16);
    color: #fcd34d;
  }
  :root[data-theme='dark'] .sb-start-card-icon--blue {
    background: rgba(79, 70, 229, 0.18);
    color: #c7d2fe;
  }
  :root[data-theme='dark'] .sb-start-card-icon--sage {
    background: rgba(16, 185, 129, 0.18);
    color: #6ee7b7;
  }
  :root[data-theme='dark'] .sb-start-card-icon--coral {
    background: rgba(236, 72, 153, 0.18);
    color: #f9a8d4;
  }

  .sb-start-card-title {
    margin: 0;
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--sl-color-text);
  }

  .sb-start-card-body {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--sl-color-gray-3);
    flex: 1;
  }

  .sb-start-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--sb-brand-blue-deep);
  }

  :root[data-theme='dark'] .sb-start-card-cta {
    color: #c7d2fe;
  }

  .sb-start-card-arrow {
    transition: transform var(--sb-duration-base) var(--sb-ease-out-quart);
  }

  .sb-start-card:hover .sb-start-card-arrow,
  .sb-start-card:focus-visible .sb-start-card-arrow {
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .sb-start-card,
    .sb-start-card-icon,
    .sb-start-card-arrow,
    .sb-start-card-glow,
    .sb-start-card::before {
      transition: none;
    }
    .sb-start-card:hover,
    .sb-start-card:focus-visible {
      transform: none;
    }
  }
</style>
