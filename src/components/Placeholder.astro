---
/**
 * Placeholder — renders an inline screenshot/video/diagram or, when no
 * asset is wired up yet, a labeled empty space so it's obvious in dev
 * which spots still need filling.
 *
 * Behavior:
 *   - If `src` is provided, render the asset (always — dev AND prod).
 *     The `caption` becomes the visible <figcaption> AND the alt text
 *     (unless `alt` is explicitly passed). This is the documented spot.
 *   - If `src` is NOT provided, fall back to the dashed-box placeholder.
 *     The placeholder is visible ONLY in dev (import.meta.env.DEV) so
 *     unfilled slots can't accidentally ship to production.
 *
 * Usage in .mdx files:
 *   import Placeholder from '@/components/Placeholder.astro';
 *
 *   // Empty placeholder (dev-only):
 *   <Placeholder type="screenshot" caption="Brief composer with hover state" />
 *
 *   // Filled placeholder (renders in dev + prod):
 *   <Placeholder
 *     type="screenshot"
 *     src="/screenshots/getting-started/signup-form.png"
 *     caption="The /signup page with email, name, and password fields visible"
 *   />
 *
 * Props:
 *   type    — 'screenshot' | 'video' | 'diagram' (informational)
 *   caption — required: visible figcaption + default alt text. Be specific.
 *   src     — optional path to the asset. When set, the dashed box becomes a real <img>.
 *   alt     — optional override for alt text. Defaults to `caption`.
 *   aspect  — CSS aspect-ratio (e.g., '16/9', '4/3', '1/1'); default '16/9'
 *             Applied to placeholder box AND to images, so reflows are minimal
 *             before the image decodes.
 *   width   — optional max-width in px; default fills container
 */

interface Props {
  type?: 'screenshot' | 'video' | 'diagram';
  caption: string;
  src?: string;
  alt?: string;
  aspect?: string;
  width?: number;
}

const {
  type = 'screenshot',
  caption,
  src,
  alt,
  aspect = '16/9',
  width,
} = Astro.props;

const labelMap = {
  screenshot: 'SCREENSHOT',
  video: 'VIDEO',
  diagram: 'DIAGRAM',
} as const;

const altText = alt ?? caption;
---

{
  src ? (
    <figure
      class="sb-placeholder sb-placeholder--filled"
      data-type={type}
      style={width ? `max-width: ${width}px;` : undefined}
    >
      <img
        class="sb-placeholder-image"
        src={src}
        alt={altText}
        loading="lazy"
        decoding="async"
        style={`aspect-ratio: ${aspect};`}
      />
      <figcaption class="sb-placeholder-figcaption">{caption}</figcaption>
    </figure>
  ) : (
    import.meta.env.DEV && (
      <figure
        class="sb-placeholder"
        data-type={type}
        style={width ? `max-width: ${width}px;` : undefined}
      >
        <div class="sb-placeholder-inner" style={`aspect-ratio: ${aspect};`}>
          <span class="sb-placeholder-label">{labelMap[type]} PLACEHOLDER</span>
          <span class="sb-placeholder-caption">{caption}</span>
          <span class="sb-placeholder-meta">{aspect}</span>
        </div>
      </figure>
    )
  )
}

<style>
  /* Placeholder block — visible only in dev. Tasteful dashed-border crate
   * with the caption visible. Distinctive enough that Peter can't miss
   * un-filled spots when scanning a page. */

  .sb-placeholder {
    display: block;
    margin: 1.75rem 0;
    padding: 0;
  }

  .sb-placeholder-inner {
    position: relative;
    width: 100%;
    border: 2px dashed var(--sb-brand-blue);
    border-radius: var(--sb-radius-lg);
    background:
      repeating-linear-gradient(
        45deg,
        rgba(79, 70, 229, 0.03) 0,
        rgba(79, 70, 229, 0.03) 12px,
        rgba(124, 58, 237, 0.03) 12px,
        rgba(124, 58, 237, 0.03) 24px
      );
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.5rem;
    color: var(--sb-brand-blue-deep);
  }

  .sb-placeholder-label {
    font-family: var(--sb-font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    background: var(--sb-paper);
    border: 1px solid var(--sb-brand-blue);
    color: var(--sb-brand-blue-deep);
  }

  .sb-placeholder-caption {
    font-size: 14px;
    font-weight: 500;
    text-align: center;
    max-width: 36rem;
    color: var(--sb-ink);
    line-height: 1.4;
  }

  .sb-placeholder-meta {
    font-family: var(--sb-font-mono);
    font-size: 11px;
    color: var(--sb-ink-soft);
    opacity: 0.7;
  }

  :root[data-theme='dark'] .sb-placeholder-inner {
    color: #c7d2fe;
  }

  :root[data-theme='dark'] .sb-placeholder-label {
    background: var(--sl-color-bg);
    color: #c7d2fe;
  }

  :root[data-theme='dark'] .sb-placeholder-caption {
    color: var(--sl-color-text);
  }

  /* Filled variant — real image is in place. */
  .sb-placeholder--filled {
    display: block;
    margin: 1.75rem 0;
    padding: 0;
  }

  .sb-placeholder-image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--sb-radius-lg);
    border: 1px solid var(--sb-border, rgba(0, 0, 0, 0.08));
    background: var(--sb-paper);
    /* Use CSS shadow tokens if available, otherwise a subtle default. */
    box-shadow: var(--sb-shadow-md, 0 2px 8px rgba(15, 23, 42, 0.06));
  }

  .sb-placeholder-figcaption {
    margin-top: 0.625rem;
    font-size: 13px;
    line-height: 1.45;
    color: var(--sb-ink-soft);
    text-align: center;
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
  }

  :root[data-theme='dark'] .sb-placeholder-image {
    border-color: rgba(255, 255, 255, 0.08);
    background: var(--sl-color-bg);
  }

  :root[data-theme='dark'] .sb-placeholder-figcaption {
    color: var(--sl-color-gray-3, #94a3b8);
  }
</style>
